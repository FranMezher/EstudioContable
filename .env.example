AUTH_URL="http://localhost:3000"

# --- Vercel Blob (almacenamiento de PDFs) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# --- Resend (envío de emails) ---
RESEND_API_KEY="re_xxxxxxxxxxxx"
