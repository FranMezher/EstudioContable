# ==========================================================
#  Mezher Pampin — Recibos de Sueldo · Variables de entorno
# ==========================================================
# Copiá este archivo como .env y completá los valores reales.

# --- Base de datos PostgreSQL (Neon) ---
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# Generá uno con: npx auth secret
AUTH_SECRET="reemplazar-por-un-secreto-largo-aleatorio"
AUTH_URL="http://localhost:3000"

# --- Vercel Blob (almacenamiento privado de los PDFs) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# --- Usuario inicial del estudio (para el seed) ---
SEED_ADMIN_EMAIL="mezherg43@gmail.com"
SEED_ADMIN_PASSWORD="cambiar-esta-clave"
SEED_ADMIN_NAME="Administrador"

# ==========================================================
#  Solo en la PC que corre el importador de recibos
#  (ver docs/IMPORTADOR.md)
# ==========================================================
# RECIBOS_ROOT="C:\\Recibos"
# API_URL="https://recibos.mezherpampin.com.ar"
# API_KEY="mp_live_xxxxxxxxxxxxxxxxxxxx"
